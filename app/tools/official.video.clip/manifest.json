{
  "id": "official.video.clip",
  "name": "Video Clip",
  "version": "0.1.0",
  "author": "omniagent",
  "description": "Cut a video segment by start and end time.",
  "io": {
    "inputs": [
      {
        "name": "file",
        "required": true,
        "type": "file",
        "accepts": [".mp4", ".mov", ".mkv", ".webm"]
      },
      {
        "default": 0,
        "name": "start_seconds",
        "type": "number",
        "required": false
      },
      {
        "default": 10,
        "name": "end_seconds",
        "type": "number",
        "required": false
      }
    ],
    "outputs": [
      {
        "format": "video",
        "name": "result",
        "type": "file"
      }
    ]
  },
  "runtime": {
    "language": "python",
    "dependencies": ["ffmpeg-python==0.2.0"],
    "timeout": 120,
    "memory": "512MB"
  },
  "tags": ["video", "clip", "media"],
  "stats": {
    "created_at": "2026-02-25T00:00:00Z",
    "usage_count": 0,
    "success_rate": 0
  },
  "claude_skill_compatible": true
}
