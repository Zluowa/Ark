{
  "id": "official.image.crop",
  "name": "Image Crop",
  "version": "0.1.0",
  "author": "omniagent",
  "description": "Crop an image by rectangle coordinates.",
  "io": {
    "inputs": [
      {
        "name": "file",
        "required": true,
        "type": "file",
        "accepts": [".png", ".jpg", ".jpeg", ".webp"]
      },
      {
        "default": 0,
        "name": "x",
        "type": "number",
        "required": false
      },
      {
        "default": 0,
        "name": "y",
        "type": "number",
        "required": false
      },
      {
        "default": 256,
        "name": "width",
        "type": "number",
        "required": false
      },
      {
        "default": 256,
        "name": "height",
        "type": "number",
        "required": false
      }
    ],
    "outputs": [
      {
        "format": "image",
        "name": "result",
        "type": "file"
      }
    ]
  },
  "runtime": {
    "language": "python",
    "dependencies": ["pillow==11.1.0"],
    "timeout": 45,
    "memory": "256MB"
  },
  "tags": ["image", "crop", "media"],
  "stats": {
    "created_at": "2026-02-25T00:00:00Z",
    "usage_count": 0,
    "success_rate": 0
  },
  "claude_skill_compatible": true
}
