{
  "id": "official.pdf.merge",
  "name": "PDF Merge",
  "version": "0.1.0",
  "author": "omniagent",
  "description": "Merge multiple PDF files into one document.",
  "io": {
    "inputs": [
      {
        "name": "files",
        "required": true,
        "type": "file[]",
        "accepts": [".pdf"]
      }
    ],
    "outputs": [
      {
        "format": "pdf",
        "name": "result",
        "type": "file"
      }
    ]
  },
  "runtime": {
    "language": "python",
    "dependencies": ["pypdf==4.3.1"],
    "timeout": 90,
    "memory": "512MB"
  },
  "tags": ["pdf", "merge", "document"],
  "stats": {
    "created_at": "2026-02-25T00:00:00Z",
    "usage_count": 0,
    "success_rate": 0
  },
  "claude_skill_compatible": true
}
