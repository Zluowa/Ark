{
  "id": "official.video.extract_audio",
  "name": "Video Extract Audio",
  "version": "0.1.0",
  "author": "omniagent",
  "description": "Extract audio track from a video file.",
  "io": {
    "inputs": [
      {
        "name": "file",
        "required": true,
        "type": "file",
        "accepts": [".mp4", ".mov", ".mkv", ".webm"]
      },
      {
        "default": "mp3",
        "name": "target_format",
        "type": "string",
        "required": false
      }
    ],
    "outputs": [
      {
        "format": "audio",
        "name": "result",
        "type": "file"
      }
    ]
  },
  "runtime": {
    "language": "python",
    "dependencies": ["ffmpeg-python==0.2.0"],
    "timeout": 120,
    "memory": "512MB"
  },
  "tags": ["video", "audio", "extract"],
  "stats": {
    "created_at": "2026-02-25T00:00:00Z",
    "usage_count": 0,
    "success_rate": 0
  },
  "claude_skill_compatible": true
}
