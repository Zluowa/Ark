{
  "id": "official.pdf.compress",
  "name": "PDF Compress",
  "version": "0.1.0",
  "author": "omniagent",
  "description": "Compress PDF file size with adjustable quality.",
  "io": {
    "inputs": [
      {
        "name": "file",
        "required": true,
        "type": "file",
        "accepts": [".pdf"]
      },
      {
        "default": 75,
        "name": "quality",
        "minimum": 1,
        "required": false,
        "type": "number",
        "maximum": 100
      }
    ],
    "outputs": [
      {
        "format": "pdf",
        "name": "result",
        "type": "file"
      }
    ]
  },
  "runtime": {
    "language": "python",
    "dependencies": ["pikepdf==9.2.0"],
    "timeout": 60,
    "memory": "512MB"
  },
  "tags": ["pdf", "compress", "document"],
  "stats": {
    "created_at": "2026-02-25T00:00:00Z",
    "usage_count": 0,
    "success_rate": 0
  },
  "claude_skill_compatible": true
}
