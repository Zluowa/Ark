{
  "id": "official.image.compress",
  "name": "Image Compress",
  "version": "0.1.0",
  "author": "omniagent",
  "description": "Compress image files while preserving visual quality.",
  "io": {
    "inputs": [
      {
        "name": "file",
        "required": true,
        "type": "file",
        "accepts": [".png", ".jpg", ".jpeg", ".webp"]
      },
      {
        "default": 80,
        "name": "quality",
        "minimum": 1,
        "required": false,
        "type": "number",
        "maximum": 100
      }
    ],
    "outputs": [
      {
        "format": "image",
        "name": "result",
        "type": "file"
      }
    ]
  },
  "runtime": {
    "language": "python",
    "dependencies": ["pillow==11.1.0"],
    "timeout": 45,
    "memory": "256MB"
  },
  "tags": ["image", "compress", "media"],
  "stats": {
    "created_at": "2026-02-25T00:00:00Z",
    "usage_count": 0,
    "success_rate": 0
  },
  "claude_skill_compatible": true
}
