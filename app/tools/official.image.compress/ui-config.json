{
  "layout": "VerticalStack",
  "props": {
    "gap": "md"
  },
  "children": [
    {
      "component": "FileDropzone",
      "props": {
        "accept": ".png,.jpg,.jpeg,.webp",
        "placeholder": "Drop input file",
        "binding": "input.file"
      }
    },
    {
      "component": "Slider",
      "props": {
        "label": "Quality",
        "min": 1,
        "max": 100,
        "step": 1,
        "unit": "%",
        "binding": "params.quality"
      }
    },
    {
      "component": "DownloadButton",
      "props": {
        "binding": "result.outputFile"
      },
      "condition": {
        "field": "state.status",
        "eq": "completed"
      }
    }
  ]
}
