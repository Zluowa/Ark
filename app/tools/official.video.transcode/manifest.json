{
  "id": "official.video.transcode",
  "name": "Video Transcode",
  "version": "0.1.0",
  "author": "omniagent",
  "description": "Transcode video file to target codec and container.",
  "io": {
    "inputs": [
      {
        "name": "file",
        "required": true,
        "type": "file",
        "accepts": [".mp4", ".mov", ".mkv", ".webm"]
      },
      {
        "default": "mp4",
        "name": "target_format",
        "type": "string",
        "required": false
      }
    ],
    "outputs": [
      {
        "format": "video",
        "name": "result",
        "type": "file"
      }
    ]
  },
  "runtime": {
    "language": "python",
    "dependencies": ["ffmpeg-python==0.2.0"],
    "timeout": 180,
    "memory": "1GB"
  },
  "tags": ["video", "transcode", "media"],
  "stats": {
    "created_at": "2026-02-25T00:00:00Z",
    "usage_count": 0,
    "success_rate": 0
  },
  "claude_skill_compatible": true
}
