{
  "productName": "OmniAgent",
  "version": "0.1.0",
  "identifier": "com.omniagent.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../chat-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OmniAgent",
        "width": 380,
        "height": 220,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ]
  },
  "plugins": {
    "shell": { "open": true }
  }
}
